# Copy to `.env` at the repo root (gitignored) and fill in.
# Loaded by detection.notifications.telegram.load_env() — every key lands in
# os.environ. Same format the Paper 1 / legacy repos use.

# Hugging Face token — lets the diffusion_bg arm pull gated FLUX.1-Fill-dev
# without `hf auth login`. Create at https://huggingface.co/settings/tokens
# (read scope) and accept the model license at
# https://huggingface.co/black-forest-labs/FLUX.1-Fill-dev
HF_TOKEN=

# Telegram run notifications (optional — absent = notifications disabled).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
