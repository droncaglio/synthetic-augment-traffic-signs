# Datasets & pesos — NUNCA versionar (repo público)
data/
runs/
outputs/
# per-run YOLO outputs (weights, preds, ap_report.json) + rsync'd dets from the workstation
# (subset baseline, open-set variants, and the full-201-class runs — all regenerable/backed up)
experiments*/
*.zip
*.pt
*.pth
*.onnx

# Python
__pycache__/
*.py[cod]
.venv/
venv/
/env/*                    # ignore a local virtualenv named env/ ...
!/env/environment.yml     # ... but keep the tracked conda spec
.pytest_cache/
.ipynb_checkpoints/

# Análise pesada
*.parquet
analysis/**/*.png
!analysis/**/.gitkeep

# QA visual dos sintéticos — não vazar método antes da submissão (repo público)
reports/qa/
# saída gerada do grid (regenerável; não versionar)
reports/det/

# Planejamento/orientação PRIVADOS — nunca em repo público (só os .bib ficam)
refs/*.pdf

# Status efêmero do grid
batch_status*.json

# Logs
*.log

# Segredos (Telegram)
.env

# OS/editor
.DS_Store
.idea/
.vscode/
